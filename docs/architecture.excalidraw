      "updated": 1776643460513,
      "link": null,
      "locked": false,
      "text": "struct CarTelemetryData\n{\n    uint16 m_speed;\n    float m_throttle;\n    float m_steer;\n    float m_brake;\n    uint8 m_clutch;\n    int8 m_gear;\n    uint16 m_engineRPM;\n    uint8 m_drs;\n    uint8 m_revLightsPercent;\n    uint16 m_revLightsBitValue;\n    uint16 m_brakesTemperature[4];\n    uint8 m_tyresSurfaceTemperature[4];\n    uint8 m_tyresInnerTemperature[4];\n    uint16 m_engineTemperature;\n    float m_tyresPressure[4];\n    uint8 m_surfaceType[4];\n};",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "struct CarTelemetryData\n{\n    uint16 m_speed;\n    float m_throttle;\n    float m_steer;\n    float m_brake;\n    uint8 m_clutch;\n    int8 m_gear;\n    uint16 m_engineRPM;\n    uint8 m_drs;\n    uint8 m_revLightsPercent;\n    uint16 m_revLightsBitValue;\n    uint16 m_brakesTemperature[4];\n    uint8 m_tyresSurfaceTemperature[4];\n    uint8 m_tyresInnerTemperature[4];\n    uint16 m_engineTemperature;\n    float m_tyresPressure[4];\n    uint8 m_surfaceType[4];\n};",
      "autoResize": false,
      "lineHeight": 1.25
    },
